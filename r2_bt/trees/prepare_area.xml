<?xml version="1.0"?>
<!--
  prepare_area.xml — 准备区局部执行树

  只执行准备区流程：移动到矛头准备区，等待 ARES tool service 完成。
  固定参数来自 match_config 的 prepare.* 字段。
-->
<root BTCPP_format="4" main_tree_to_execute="PrepareArea">
  <BehaviorTree ID="PrepareArea">
    <Sequence>

      <Sequence name="PREPARE_01_MOVE_TO_SPEAR_AREA">
        <RetrySegment num_attempts="3">
          <MoveToPose target_x="{prepare_spear_prep_target_x}"
                      target_y="{prepare_spear_prep_target_y}"
                      target_yaw="{prepare_spear_prep_target_yaw}"
                      max_speed="{prepare_spear_prep_max_speed}"
                      pid_profile="{prepare_spear_prep_pid_profile}"
                      timeout_sec="{prepare_spear_prep_timeout_sec}"
                      error_msg="{last_error}"/>
        </RetrySegment>
      </Sequence>

      <Sequence name="PREPARE_02_WAIT_BUILD_SIGNAL">
        <WaitForIntSignal signal_topic="{prepare_deck_topic}"
                          expected_value="{prepare_build_signal}"
                          timeout_sec="{prepare_build_timeout_sec}"
                          received_value="{prepare_received_signal}"
                          message="{last_error}"/>
      </Sequence>

      <Sequence name="PREPARE_03_WAIT_ARES_TOOL">
        <RetrySegment num_attempts="3">
          <AresToolAction action="{prepare_ares_tool_action}"
                          service_name="{prepare_ares_tool_service_name}"
                          timeout_sec="{prepare_ares_tool_timeout_sec}"
                          arg0="{prepare_ares_tool_arg0}"
                          arg1="{prepare_ares_tool_arg1}"
                          arg2="{prepare_ares_tool_arg2}"
                          arg3="{prepare_ares_tool_arg3}"
                          message="{last_error}"/>
        </RetrySegment>
      </Sequence>

      <SetDebugStatus execution_state="MISSION_SUCCESS" active_action="" last_error=""/>

    </Sequence>
  </BehaviorTree>
</root>
