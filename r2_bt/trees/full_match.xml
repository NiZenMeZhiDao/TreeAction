<?xml version="1.0"?>
<!--
  full_match.xml — 全场完整行为树（重构版）

  适用场景: 完整比赛流程 (准备区 → 梅林区 → 竞技区)

  架构:
    准备区 & 竞技区: 固定流程，直接读取命名 blackboard 变量，不再 PopNextSegment
    梅林区:          ForEachSegment → PopNextMeilinSegment → SwitchSegmentType，遇 PLAN_DONE 退出
                     Move 显式执行 PlanMove → StepMotionControl → MoveToPose 到目标格中心 → CommitMove
                     Fetch 作为独立动作节点，内部处理抓取前平移与 tool/arm 抓取

  启动示例:
    ros2 launch r2_bt bt_engine.launch.py param_config:=config/param_red.yaml
    ros2 launch r2_bt bt_engine.launch.py param_config:=config/param_blue.yaml

  也可单独调试梅林区:
    ros2 launch r2_bt bt_engine.launch.py tree_file:=meilin_stage.xml

  Groot2 监控: 默认端口 1667
-->
<root BTCPP_format="4" main_tree_to_execute="FullMatch">

  <!-- ========== 顶层 ========== -->
  <BehaviorTree ID="FullMatch">
    <Sequence>
      <SubTree ID="PrepareArea" _autoremap="1" />
      <SubTree ID="MeilinArea" _autoremap="1" />
      <SubTree ID="FinalArea" _autoremap="1" />
      <SetDebugStatus execution_state="MISSION_SUCCESS" active_action="" last_error=""/>
    </Sequence>
  </BehaviorTree>

  <!-- ====== 准备区：调用 /pick_action 夹取矛头，然后并行移动到对接待定区与 dock_extend ====== -->
  <BehaviorTree ID="PrepareArea">
    <SequenceWithMemory>

      <Sequence name="PREPARE_01_MOVE_TO_SPEAR_PICKUP">
        <RetrySegment num_attempts="{prepare_motion_retry_attempts}">
          <MoveToPose target_x="{prepare_spear_pickup_target_x}"
                      target_y="{prepare_spear_pickup_target_y}"
                      target_yaw="{prepare_spear_pickup_target_yaw}"
                      frame_id="{prepare_spear_pickup_frame_id}"
                      pid_profile="{prepare_motion_pid_profile}"
                      timeout_sec="{prepare_motion_timeout_sec}"
                      error_msg="{last_error}"/>
        </RetrySegment>
      </Sequence>

      <Sequence name="PREPARE_02_GRASP_SPEAR">
        <RetrySegment num_attempts="{prepare_pick_action_retry_attempts}">
          <PickAction server_name="{prepare_pick_action_server_name}"
                      expected_count="{prepare_pick_action_expected_count}"
                      timeout_sec="{prepare_pick_action_timeout_sec}"
                      message="{last_error}"/>
        </RetrySegment>
      </Sequence>

      <Parallel name="PREPARE_03_DOCK_STANDBY_AND_EXTEND"
                success_count="2"
                failure_count="1">
        <RetrySegment num_attempts="{prepare_motion_retry_attempts}">
          <MoveToPose target_x="{prepare_dock_standby_target_x}"
                      target_y="{prepare_dock_standby_target_y}"
                      target_yaw="{prepare_dock_standby_target_yaw}"
                      frame_id="{prepare_dock_standby_frame_id}"
                      pid_profile="{prepare_motion_pid_profile}"
                      timeout_sec="{prepare_motion_timeout_sec}"
                      error_msg="{last_error}"/>
        </RetrySegment>

        <RetrySegment num_attempts="{prepare_spear_tool_retry_attempts}">
          <AresToolAction action="{prepare_spear_tool_dock_extend_action}"
                          service_name="{prepare_spear_tool_service_name}"
                          timeout_sec="{prepare_spear_tool_dock_extend_timeout_sec}"
                          arg0="{prepare_spear_tool_arg0}"
                          arg1="{prepare_spear_tool_arg1}"
                          arg2="{prepare_spear_tool_arg2}"
                          arg3="{prepare_spear_tool_arg3}"
                          message="{last_error}"/>
        </RetrySegment>
      </Parallel>

    </SequenceWithMemory>
  </BehaviorTree>

  <!--
    ====== 梅林区：直接消费 /mf_action_seq 解析出的 move/fetch 队列 ======

    Move:
      - MeilinPlanMove 计算入口、目标中心、step goal
      - StepMotionControl 仅在高度变化时调用 /step_motion_control
      - MoveToPose 到目标格中心
      - MeilinCommitMove 更新当前格/高度/yaw

    Fetch:
      - Fetch 独立执行，内部处理抓取前平移、必要 direct height、tool arm_grasp
  -->
  <BehaviorTree ID="MeilinArea">
    <ForEachSegment stop_type="PLAN_DONE">
      <Sequence>
        <PopNextMeilinSegment queue="{segment_queue}"
                              segment_type="{segment_type}"
                              move_row="{move_row}"
                              move_col="{move_col}"
                              target_height_mm="{target_height_mm}"
                              kfs_row="{kfs_row}"
                              kfs_col="{kfs_col}"
                              height_diff="{height_diff}"
                              target_yaw="{target_yaw}"/>
        <SwitchSegmentType segment_type="{segment_type}">

          <Sequence name="move">
            <MeilinPlanMove name="MEILIN_01_PLAN_MOVE"
                            move_row="{move_row}"
                            move_col="{move_col}"
                            target_height_mm="{target_height_mm}"
                            target_yaw="{target_yaw}"
                            target_x="{move_target_x}"
                            target_y="{move_target_y}"
                            move_target_yaw="{move_target_yaw}"
                            align_timeout_sec="{move_align_timeout_sec}"
                            entry_move="{move_entry_move}"
                            step_needed="{move_step_needed}"
                            center_motion_needed="{move_center_motion_needed}"
                            step_mode="{move_step_mode}"
                            step_direction="{move_step_direction}"
                            step_height="{move_step_height}"
                            step_correction_x="{move_step_correction_x}"
                            step_correction_y="{move_step_correction_y}"
                            step_correction_yaw_deg="{move_step_correction_yaw_deg}"
                            step_timeout_sec="{move_step_timeout_sec}"
                            message="{last_error}"/>

            <StepMotionControl name="MEILIN_02_STEP_IF_HEIGHT_CHANGED"
                               enabled="{move_step_needed}"
                               mode="{move_step_mode}"
                               direction="{move_step_direction}"
                               height="{move_step_height}"
                               correction_x="{move_step_correction_x}"
                               correction_y="{move_step_correction_y}"
                               correction_yaw_deg="{move_step_correction_yaw_deg}"
                               timeout_sec="{move_step_timeout_sec}"
                               message="{last_error}"/>

            <MoveToPose name="MEILIN_03_MOVE_TO_TARGET_CENTER"
                        enabled="{move_center_motion_needed}"
                        target_x="{move_target_x}"
                        target_y="{move_target_y}"
                        target_yaw="{move_target_yaw}"
                        pid_profile="0"
                        timeout_sec="{move_align_timeout_sec}"
                        error_msg="{last_error}"/>

            <MeilinCommitMove name="MEILIN_04_COMMIT_MOVE_STATE"
                              move_row="{move_row}"
                              move_col="{move_col}"
                              target_height_mm="{target_height_mm}"
                              target_yaw="{target_yaw}"
                              entry_move="{move_entry_move}"
                              message="{last_error}"/>
          </Sequence>

          <Sequence name="fetch">
            <Fetch name="MEILIN_FETCH"
                   kfs_row="{kfs_row}"
                   kfs_col="{kfs_col}"
                   height_diff="{height_diff}"
                   target_yaw="{target_yaw}"
                   message="{last_error}"/>
          </Sequence>

          <Sequence name="PLAN_DONE">
            <SetDebugStatus execution_state="MEILIN_SUCCESS" active_action="" last_error=""/>
          </Sequence>

          <Sequence name="default">
            <SetDebugStatus execution_state="ACTION_FAILED" active_action="SegmentDispatch"
                            last_error="Unsupported segment_type in MeilinArea"/>
          </Sequence>

        </SwitchSegmentType>
      </Sequence>
    </ForEachSegment>
  </BehaviorTree>

  <!-- ====== 竞技区：按参数 waypoint 列表到待命位后循环等待 deck 指令 ====== -->
  <BehaviorTree ID="FinalArea">
    <Sequence>

      <Sequence name="FINAL_00_MOVE_TO_STANDBY_WAYPOINTS">
        <MoveThroughFinalWaypoints height_topic="{final_chassis_height_topic}"
                                   height_wp1="{final_chassis_height_wp1}"
                                   height_wp3="{final_chassis_height_wp3}"
                                   settle_sec="{final_chassis_height_settle_sec}"
                                   retry_attempts="3"
                                   message="{last_error}"/>
      </Sequence>

      <Repeat num_cycles="-1">
        <Sequence name="FINAL_LOOP">

          <WaitForIntSignal signal_topic="{final_deck_topic}"
                            expected_values="1,2,3,4,5,6"
                            timeout_sec="{final_command_timeout_sec}"
                            received_value="{final_command}"
                            message="{last_error}"/>

          <SelectFinalTarget command="{final_command}"
                             layer="{final_layer}"
                             column="{final_column}"
                             flow="{final_flow}"
                             target_x="{final_target_x}"
                             target_y="{final_target_y}"
                             target_yaw="{final_target_yaw}"
                             pid_profile="{final_target_pid_profile}"
                             timeout_sec="{final_target_timeout_sec}"
                             message="{last_error}"/>

          <RetrySegment num_attempts="3">
            <MoveToPose target_x="{final_target_x}"
                        target_y="{final_target_y}"
                        target_yaw="{final_target_yaw}"
                        pid_profile="{final_target_pid_profile}"
                        timeout_sec="{final_target_timeout_sec}"
                        error_msg="{last_error}"/>
          </RetrySegment>

          <SwitchSegmentType segment_type="{final_flow}">

            <Sequence name="LAYER2">
              <RetrySegment num_attempts="{final_place_action_retry_attempts}">
                <AresToolAction action="{final_place_mid_action}"
                                service_name="{final_place_action_service_name}"
                                timeout_sec="{final_place_action_timeout_sec}"
                                arg0="{final_place_action_arg0}"
                                arg1="{final_place_action_arg1}"
                                arg2="{final_place_action_arg2}"
                                arg3="{final_place_action_arg3}"
                                message="{last_error}"/>
              </RetrySegment>
              <WaitForIntSignal signal_topic="{final_deck_topic}"
                                expected_value="{final_place_signal}"
                                timeout_sec="{final_place_signal_timeout_sec}"
                                received_value="{final_place_received_signal}"
                                message="{last_error}"/>
              <RetrySegment num_attempts="{final_place_action_retry_attempts}">
                <AresToolAction action="{final_place_mid_action}"
                                service_name="{final_place_action_service_name}"
                                timeout_sec="{final_place_action_timeout_sec}"
                                arg0="{final_place_action_arg0}"
                                arg1="{final_place_action_arg1}"
                                arg2="{final_place_action_arg2}"
                                arg3="{final_place_action_arg3}"
                                message="{last_error}"/>
              </RetrySegment>
            </Sequence>

            <Sequence name="LAYER3">
              <WaitForIntSignal signal_topic="{final_deck_topic}"
                                expected_value="{final_place_signal}"
                                timeout_sec="{final_place_signal_timeout_sec}"
                                received_value="{final_place_received_signal}"
                                message="{last_error}"/>
              <RetrySegment num_attempts="{final_place_action_retry_attempts}">
                <AresToolAction action="{final_place_high_action}"
                                service_name="{final_place_action_service_name}"
                                timeout_sec="{final_place_action_timeout_sec}"
                                arg0="{final_place_action_arg0}"
                                arg1="{final_place_action_arg1}"
                                arg2="{final_place_action_arg2}"
                                arg3="{final_place_action_arg3}"
                                message="{last_error}"/>
              </RetrySegment>
            </Sequence>

            <Sequence name="default">
              <SetDebugStatus execution_state="ACTION_FAILED" active_action="FinalDispatch"
                              last_error="Unsupported final_flow"/>
            </Sequence>

          </SwitchSegmentType>

          <WaitSeconds seconds="{final_post_place_wait_sec}"/>

          <RetrySegment num_attempts="3">
            <MoveToPose target_x="{final_standby_target_x}"
                        target_y="{final_standby_target_y}"
                        target_yaw="{final_standby_target_yaw}"
                        pid_profile="{final_standby_pid_profile}"
                        timeout_sec="{final_standby_timeout_sec}"
                        error_msg="{last_error}"/>
          </RetrySegment>

        </Sequence>
      </Repeat>

    </Sequence>
  </BehaviorTree>

</root>
