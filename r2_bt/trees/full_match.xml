<?xml version="1.0"?>
<!--
  full_match.xml — 全场完整行为树（重构版）

  适用场景: 完整比赛流程 (准备区 → 梅林区 → 竞技区)

  架构:
    准备区 & 竞技区: 固定流程，直接读取命名 blackboard 变量，不再 PopNextSegment
    梅林区:          ForEachSegment → PopNextMeilinSegment → SwitchSegmentType，遇 PLAN_DONE 退出
                     Move 显式执行 PlanMove → MoveToPose 到目标格中心 → StepMotionControl → CommitMove
                     Fetch 作为独立动作节点，内部处理抓取前平移与 tool/arm 抓取

  启动示例:
    ros2 launch r2_bt bt_engine.launch.py param_config:=config/param_red.yaml
    ros2 launch r2_bt bt_engine.launch.py param_config:=config/param_blue.yaml

  也可单独调试梅林区:
    ros2 launch r2_bt bt_engine.launch.py tree_file:=meilin_stage.xml

  Groot2 监控: 默认端口 1667
-->
<root BTCPP_format="4" main_tree_to_execute="FullMatch">

  <!-- ========== 顶层 ========== -->
  <BehaviorTree ID="FullMatch">
    <Sequence>
      <SubTree ID="PrepareArea" _autoremap="1" />
      <WaitSeconds seconds="{prepare_to_meilin_wait_sec}"/>
      <SubTree ID="MeilinArea" _autoremap="1" />
      <SubTree ID="FinalArea" _autoremap="1" />
      <SetDebugStatus execution_state="MISSION_SUCCESS" active_action="" last_error=""/>
    </Sequence>
  </BehaviorTree>

  <!-- ====== 准备区：调用 /pick_action 夹取矛头，然后并行移动到对接待定区与 dock_extend ====== -->
  <BehaviorTree ID="PrepareArea">
    <SequenceWithMemory>

      <Sequence name="PREPARE_01_MOVE_TO_SPEAR_PICKUP">
        <RetrySegment num_attempts="{prepare_motion_retry_attempts}">
          <MoveToPose target_x="{prepare_spear_pickup_target_x}"
                      target_y="{prepare_spear_pickup_target_y}"
                      target_yaw="{prepare_spear_pickup_target_yaw}"
                      frame_id="{prepare_spear_pickup_frame_id}"
                      pid_profile="{prepare_spear_pickup_pid_profile}"
                      max_vel="{prepare_spear_pickup_max_vel}"
                      max_wz="{prepare_spear_pickup_max_wz}"
                      timeout_sec="{prepare_spear_pickup_timeout_sec}"
                      error_msg="{last_error}"/>
        </RetrySegment>
      </Sequence>

      <Sequence name="PREPARE_02_GRASP_SPEAR">
        <RetrySegment num_attempts="{prepare_pick_action_retry_attempts}">
          <PickAction server_name="{prepare_pick_action_server_name}"
                      expected_count="{prepare_pick_action_expected_count}"
                      timeout_sec="{prepare_pick_action_timeout_sec}"
                      message="{last_error}"/>
        </RetrySegment>
      </Sequence>

      <Parallel name="PREPARE_03_DOCK_STANDBY_AND_EXTEND"
                success_count="2"
                failure_count="1">
        <RetrySegment num_attempts="{prepare_motion_retry_attempts}">
          <MoveToPose target_x="{prepare_dock_standby_target_x}"
                      target_y="{prepare_dock_standby_target_y}"
                      target_yaw="{prepare_dock_standby_target_yaw}"
                      frame_id="{prepare_dock_standby_frame_id}"
                      pid_profile="{prepare_dock_standby_pid_profile}"
                      max_vel="{prepare_dock_standby_max_vel}"
                      max_wz="{prepare_dock_standby_max_wz}"
                      timeout_sec="{prepare_dock_standby_timeout_sec}"
                      error_msg="{last_error}"/>
        </RetrySegment>

        <RetrySegment num_attempts="{prepare_spear_tool_retry_attempts}">
          <AresToolAction action="{prepare_spear_tool_dock_extend_action}"
                          service_name="{prepare_spear_tool_service_name}"
                          timeout_sec="{prepare_spear_tool_dock_extend_timeout_sec}"
                          arg0="{prepare_spear_tool_arg0}"
                          arg1="{prepare_spear_tool_arg1}"
                          arg2="{prepare_spear_tool_arg2}"
                          arg3="{prepare_spear_tool_arg3}"
                          message="{last_error}"/>
        </RetrySegment>
      </Parallel>

    </SequenceWithMemory>
  </BehaviorTree>

  <!--
    ====== 梅林区：直接消费 /mf_action_seq 解析出的 move/fetch 队列 ======

    Move:
      - MeilinPlanMove 计算入口、目标中心、step goal
      - MoveToPose 到目标格中心；入口跨高度 move 可提前 success
      - StepMotionControl 在高度变化时调用 /step_motion_control
      - MeilinCommitMove 更新当前格/高度/yaw

    Fetch:
      - Fetch 独立执行，内部处理抓取前平移、必要 direct height、tool arm_grasp
  -->
  <BehaviorTree ID="MeilinArea">
    <ForEachSegment stop_type="PLAN_DONE">
      <Sequence>
        <PopNextMeilinSegment queue="{segment_queue}"
                              segment_type="{segment_type}"
                              move_row="{move_row}"
                              move_col="{move_col}"
                              target_height_mm="{target_height_mm}"
                              kfs_row="{kfs_row}"
                              kfs_col="{kfs_col}"
                              height_diff="{height_diff}"
                              target_yaw="{target_yaw}"/>
        <SwitchSegmentType segment_type="{segment_type}">

          <Sequence name="move">
            <MeilinPlanMove name="MEILIN_01_PLAN_MOVE"
                            move_row="{move_row}"
                            move_col="{move_col}"
                            target_height_mm="{target_height_mm}"
                            target_yaw="{target_yaw}"
                            target_x="{move_target_x}"
                            target_y="{move_target_y}"
                            move_target_yaw="{move_target_yaw}"
                            align_timeout_sec="{move_align_timeout_sec}"
                            entry_move="{move_entry_move}"
                            step_needed="{move_step_needed}"
                            center_motion_needed="{move_center_motion_needed}"
                            step_mode="{move_step_mode}"
                            step_direction="{move_step_direction}"
                            step_height="{move_step_height}"
                            step_correction_x="{move_step_correction_x}"
                            step_correction_y="{move_step_correction_y}"
                            step_correction_yaw_deg="{move_step_correction_yaw_deg}"
                            step_timeout_sec="{move_step_timeout_sec}"
                            move_early_success_distance="{move_early_success_distance}"
                            move_early_success_yaw_tolerance="{move_early_success_yaw_tolerance}"
                            message="{last_error}"/>

            <MoveToPose name="MEILIN_02_MOVE_TO_TARGET_CENTER"
                        enabled="{move_center_motion_needed}"
                        target_x="{move_target_x}"
                        target_y="{move_target_y}"
                        target_yaw="{move_target_yaw}"
                        pid_profile="0"
                        timeout_sec="{move_align_timeout_sec}"
                        early_success_distance="{move_early_success_distance}"
                        early_success_yaw_tolerance="{move_early_success_yaw_tolerance}"
                        error_msg="{last_error}"/>

            <StepMotionControl name="MEILIN_03_STEP_IF_HEIGHT_CHANGED"
                               enabled="{move_step_needed}"
                               mode="{move_step_mode}"
                               direction="{move_step_direction}"
                               height="{move_step_height}"
                               correction_x="{move_step_correction_x}"
                               correction_y="{move_step_correction_y}"
                               correction_yaw_deg="{move_step_correction_yaw_deg}"
                               timeout_sec="{move_step_timeout_sec}"
                               message="{last_error}"/>

            <MeilinCommitMove name="MEILIN_04_COMMIT_MOVE_STATE"
                              move_row="{move_row}"
                              move_col="{move_col}"
                              target_height_mm="{target_height_mm}"
                              target_yaw="{target_yaw}"
                              entry_move="{move_entry_move}"
                              message="{last_error}"/>
          </Sequence>

          <Sequence name="fetch">
            <Fetch name="MEILIN_FETCH"
                   kfs_row="{kfs_row}"
                   kfs_col="{kfs_col}"
                   height_diff="{height_diff}"
                   target_yaw="{target_yaw}"
                   message="{last_error}"/>
          </Sequence>

          <Sequence name="PLAN_DONE">
            <SetDebugStatus execution_state="MEILIN_SUCCESS" active_action="" last_error=""/>
          </Sequence>

          <Sequence name="default">
            <SetDebugStatus execution_state="ACTION_FAILED" active_action="SegmentDispatch"
                            last_error="Unsupported segment_type in MeilinArea"/>
          </Sequence>

        </SwitchSegmentType>
      </Sequence>
    </ForEachSegment>
  </BehaviorTree>

  <!-- ====== 竞技区：按参数 waypoint 列表到待命位后循环等待 deck 指令 ====== -->
  <BehaviorTree ID="FinalArea">
    <Sequence>

      <Sequence name="FINAL_00_MOVE_TO_STANDBY_WAYPOINTS">
        <MoveThroughFinalWaypoints height_topic="{final_chassis_height_topic}"
                                   height_wp1="{final_chassis_height_wp1}"
                                   height_wp3="{final_chassis_height_wp3}"
                                   settle_sec="{final_chassis_height_settle_sec}"
                                   handoff_distance="{final_handoff_distance}"
                                   handoff_count="{final_handoff_count}"
                                   handoff_position_only="{final_handoff_position_only}"
                                   handoff_skip_brake="{final_handoff_skip_brake}"
                                   retry_attempts="3"
                                   message="{last_error}"/>
      </Sequence>

      <InitialPlaceKFS enabled="{place_kfs_initial_enabled}"
                       deck_topic="{final_deck_topic}"
                       default_command="{place_kfs_initial_default_command}"
                       prepare_action_name="{place_kfs_prepare_action_name}"
                       prepare_timeout_sec="{place_kfs_prepare_first_timeout_sec}"
                       forward_enabled="{place_kfs_forward_enabled}"
                       forward_velocity_topic="{place_kfs_forward_velocity_topic}"
                       forward_speed_mps="{place_kfs_forward_speed_mps}"
                       forward_duration_sec="{place_kfs_forward_duration_sec}"
                       forward_publish_rate_hz="{place_kfs_forward_publish_rate_hz}"
                       message="{last_error}"/>

      <Repeat num_cycles="-1">
        <Sequence name="FINAL_LOOP">
          <PlaceKFSAction server_name="{place_kfs_action_name}"
                          deck_command="0"
                          timeout_sec="{place_kfs_action_timeout_sec}"
                          message="{last_error}"/>
        </Sequence>
      </Repeat>

    </Sequence>
  </BehaviorTree>

  <TreeNodesModel>
    <Action ID="MoveToPose">
      <input_port name="enabled"/>
      <input_port name="target_x"/>
      <input_port name="target_y"/>
      <input_port name="target_yaw"/>
      <input_port name="pid_profile"/>
      <input_port name="max_vel"/>
      <input_port name="max_wz"/>
      <input_port name="timeout_sec"/>
      <input_port name="early_success_distance"/>
      <input_port name="early_success_yaw_tolerance"/>
      <input_port name="frame_id"/>
      <output_port name="error_msg"/>
    </Action>

    <Action ID="PickAction">
      <input_port name="expected_count"/>
      <input_port name="timeout_sec"/>
      <input_port name="server_name"/>
      <output_port name="message"/>
    </Action>

    <Action ID="InitialPlaceKFS">
      <input_port name="enabled"/>
      <input_port name="deck_topic"/>
      <input_port name="default_command"/>
      <input_port name="prepare_action_name"/>
      <input_port name="prepare_timeout_sec"/>
      <input_port name="forward_enabled"/>
      <input_port name="forward_velocity_topic"/>
      <input_port name="forward_speed_mps"/>
      <input_port name="forward_duration_sec"/>
      <input_port name="forward_publish_rate_hz"/>
      <output_port name="message"/>
    </Action>

    <Action ID="PlaceKFSAction">
      <input_port name="server_name"/>
      <input_port name="deck_command"/>
      <input_port name="timeout_sec"/>
      <output_port name="message"/>
    </Action>

    <Action ID="AresToolAction">
      <input_port name="action"/>
      <input_port name="service_name"/>
      <input_port name="timeout_sec"/>
      <input_port name="arg0"/>
      <input_port name="arg1"/>
      <input_port name="arg2"/>
      <input_port name="arg3"/>
      <output_port name="message"/>
    </Action>

    <Action ID="PopNextMeilinSegment">
      <input_port name="queue"/>
      <output_port name="segment_type"/>
      <output_port name="move_row"/>
      <output_port name="move_col"/>
      <output_port name="target_height_mm"/>
      <output_port name="kfs_row"/>
      <output_port name="kfs_col"/>
      <output_port name="height_diff"/>
      <output_port name="target_yaw"/>
    </Action>

    <Action ID="MeilinPlanMove">
      <input_port name="move_row"/>
      <input_port name="move_col"/>
      <input_port name="target_height_mm"/>
      <input_port name="target_yaw"/>
      <output_port name="target_x"/>
      <output_port name="target_y"/>
      <output_port name="move_target_yaw"/>
      <output_port name="align_timeout_sec"/>
      <output_port name="entry_move"/>
      <output_port name="step_needed"/>
      <output_port name="center_motion_needed"/>
      <output_port name="step_mode"/>
      <output_port name="step_direction"/>
      <output_port name="step_height"/>
      <output_port name="step_correction_x"/>
      <output_port name="step_correction_y"/>
      <output_port name="step_correction_yaw_deg"/>
      <output_port name="step_timeout_sec"/>
      <output_port name="move_early_success_distance"/>
      <output_port name="move_early_success_yaw_tolerance"/>
      <output_port name="message"/>
    </Action>

    <Action ID="StepMotionControl">
      <input_port name="enabled"/>
      <input_port name="mode"/>
      <input_port name="direction"/>
      <input_port name="height"/>
      <input_port name="correction_x"/>
      <input_port name="correction_y"/>
      <input_port name="correction_yaw_deg"/>
      <input_port name="timeout_sec"/>
      <input_port name="server_name"/>
      <output_port name="message"/>
      <output_port name="final_state"/>
    </Action>

    <Action ID="MeilinCommitMove">
      <input_port name="move_row"/>
      <input_port name="move_col"/>
      <input_port name="target_height_mm"/>
      <input_port name="target_yaw"/>
      <input_port name="entry_move"/>
      <output_port name="message"/>
    </Action>

    <Action ID="Fetch">
      <input_port name="kfs_row"/>
      <input_port name="kfs_col"/>
      <input_port name="height_diff"/>
      <input_port name="target_yaw"/>
      <output_port name="message"/>
    </Action>

    <Action ID="MoveThroughFinalWaypoints">
      <input_port name="height_topic"/>
      <input_port name="height_wp1"/>
      <input_port name="height_wp3"/>
      <input_port name="settle_sec"/>
      <input_port name="retry_attempts"/>
      <output_port name="message"/>
    </Action>

    <Action ID="WaitForIntSignal">
      <input_port name="signal_topic"/>
      <input_port name="expected_value"/>
      <input_port name="expected_values"/>
      <input_port name="timeout_sec"/>
      <output_port name="received_value"/>
      <output_port name="message"/>
    </Action>

    <Action ID="SelectFinalTarget">
      <input_port name="command"/>
      <output_port name="layer"/>
      <output_port name="column"/>
      <output_port name="flow"/>
      <output_port name="target_x"/>
      <output_port name="target_y"/>
      <output_port name="target_yaw"/>
      <output_port name="pid_profile"/>
      <output_port name="max_vel"/>
      <output_port name="max_wz"/>
      <output_port name="timeout_sec"/>
      <output_port name="message"/>
    </Action>

    <Action ID="WaitSeconds">
      <input_port name="seconds"/>
    </Action>

    <Action ID="SetDebugStatus">
      <input_port name="execution_state"/>
      <input_port name="active_action"/>
      <input_port name="last_error"/>
      <input_port name="retry_count"/>
    </Action>

    <Decorator ID="ForEachSegment">
      <input_port name="stop_type"/>
    </Decorator>

    <Decorator ID="RetrySegment">
      <input_port name="num_attempts"/>
    </Decorator>

    <Control ID="SwitchSegmentType">
      <input_port name="segment_type"/>
    </Control>
  </TreeNodesModel>

</root>
