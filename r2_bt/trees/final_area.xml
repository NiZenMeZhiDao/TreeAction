<?xml version="1.0"?>
<!--
  final_area.xml — 竞技/终局局部执行树

  只执行 FinalArea deck 控制流程。固定参数来自 param_config 的 final_area.* 字段。
-->
<root BTCPP_format="4" main_tree_to_execute="FinalArea">
  <BehaviorTree ID="FinalArea">
    <Sequence>

      <Sequence name="FINAL_00_MOVE_TO_STANDBY_WAYPOINTS">
        <MoveThroughFinalWaypoints height_topic="{final_chassis_height_topic}"
                                   height_wp1="{final_chassis_height_wp1}"
                                   height_wp3="{final_chassis_height_wp3}"
                                   settle_sec="{final_chassis_height_settle_sec}"
                                   handoff_distance="{final_handoff_distance}"
                                   handoff_count="{final_handoff_count}"
                                   handoff_position_only="{final_handoff_position_only}"
                                   handoff_skip_brake="{final_handoff_skip_brake}"
                                   retry_attempts="3"
                                   message="{last_error}"/>
      </Sequence>

      <InitialPlaceKFS enabled="{place_kfs_initial_enabled}"
                       deck_topic="{final_deck_topic}"
                       default_command="{place_kfs_initial_default_command}"
                       prepare_action_name="{place_kfs_prepare_action_name}"
                       prepare_timeout_sec="{place_kfs_prepare_first_timeout_sec}"
                       forward_enabled="{place_kfs_forward_enabled}"
                       forward_velocity_topic="{place_kfs_forward_velocity_topic}"
                       forward_speed_mps="{place_kfs_forward_speed_mps}"
                       forward_duration_sec="{place_kfs_forward_duration_sec}"
                       forward_publish_rate_hz="{place_kfs_forward_publish_rate_hz}"
                       message="{last_error}"/>

      <Repeat num_cycles="-1">
        <Sequence name="FINAL_LOOP">
          <PlaceKFSAction server_name="{place_kfs_action_name}"
                          deck_command="0"
                          timeout_sec="{place_kfs_action_timeout_sec}"
                          message="{last_error}"/>
        </Sequence>
      </Repeat>

    </Sequence>
  </BehaviorTree>
</root>
