<?xml version="1.0"?>
<!--
  full_match.xml — 全场完整行为树（重构版）

  适用场景: 完整比赛流程 (准备区 → 梅林区 → 竞技区)

  架构:
    准备区 & 竞技区: 固定流程，直接读取命名 blackboard 变量，不再 PopNextSegment
    梅林区:          ForEachSegment → PopNextMeilinSegment → SwitchSegmentType，遇 PLAN_DONE 退出

  启动示例:
    ros2 launch r2_bt bt_engine.launch.py match_config:=config/match_red.json
    ros2 launch r2_bt bt_engine.launch.py match_config:=config/match_blue.json

  也可单独调试梅林区:
    ros2 launch r2_bt bt_engine.launch.py tree_file:=meilin_stage.xml

  Groot2 监控: 默认端口 1667
-->
<root BTCPP_format="4" main_tree_to_execute="FullMatch">

  <!-- ========== 顶层 ========== -->
  <BehaviorTree ID="FullMatch">
    <Sequence>
      <SubTree ID="PrepareArea" />
      <SubTree ID="MeilinArea"  />
      <SubTree ID="FinalArea"   />
      <SetDebugStatus execution_state="MISSION_SUCCESS" active_action="" last_error=""/>
    </Sequence>
  </BehaviorTree>

  <!-- ====== 准备区：移动到矛头准备区，等待 ares_tool service 完成 ====== -->
  <BehaviorTree ID="PrepareArea">
    <Sequence>

      <Sequence name="PREPARE_01_MOVE_TO_SPEAR_AREA">
        <RetrySegment num_attempts="3">
          <MoveToPose target_x="{prepare_spear_prep_target_x}"
                      target_y="{prepare_spear_prep_target_y}"
                      target_yaw="{prepare_spear_prep_target_yaw}"
                      max_speed="{prepare_spear_prep_max_speed}"
                      pid_profile="{prepare_spear_prep_pid_profile}"
                      timeout_sec="{prepare_spear_prep_timeout_sec}"
                      error_msg="{last_error}"/>
        </RetrySegment>
      </Sequence>

      <Sequence name="PREPARE_02_WAIT_ARES_TOOL">
        <RetrySegment num_attempts="3">
          <AresToolAction action="{prepare_ares_tool_action}"
                          service_name="{prepare_ares_tool_service_name}"
                          timeout_sec="{prepare_ares_tool_timeout_sec}"
                          arg0="{prepare_ares_tool_arg0}"
                          arg1="{prepare_ares_tool_arg1}"
                          arg2="{prepare_ares_tool_arg2}"
                          arg3="{prepare_ares_tool_arg3}"
                          message="{last_error}"/>
        </RetrySegment>
      </Sequence>

    </Sequence>
  </BehaviorTree>

  <!-- ====== 梅林区：直接消费 /mf_action_seq 解析出的 move/fetch 队列 ====== -->
  <BehaviorTree ID="MeilinArea">
    <ForEachSegment stop_type="PLAN_DONE">
      <Sequence>
        <PopNextMeilinSegment queue="{segment_queue}"
                              segment_type="{segment_type}"
                              move_row="{move_row}"
                              move_col="{move_col}"
                              target_height_mm="{target_height_mm}"
                              kfs_row="{kfs_row}"
                              kfs_col="{kfs_col}"
                              height_diff="{height_diff}"
                              target_yaw="{target_yaw}"/>
        <SwitchSegmentType segment_type="{segment_type}">

          <Move name="move"
                move_row="{move_row}"
                move_col="{move_col}"
                target_height_mm="{target_height_mm}"
                target_yaw="{target_yaw}"
                message="{last_error}"/>

          <Fetch name="fetch"
                 kfs_row="{kfs_row}"
                 kfs_col="{kfs_col}"
                 height_diff="{height_diff}"
                 target_yaw="{target_yaw}"
                 message="{last_error}"/>

          <Sequence name="PLAN_DONE">
            <SetDebugStatus execution_state="MEILIN_SUCCESS" active_action="" last_error=""/>
          </Sequence>

          <Sequence name="default">
            <SetDebugStatus execution_state="ACTION_FAILED" active_action="SegmentDispatch"
                            last_error="Unsupported segment_type in MeilinArea"/>
          </Sequence>

        </SwitchSegmentType>
      </Sequence>
    </ForEachSegment>
  </BehaviorTree>

  <!-- ====== 竞技区：固定 5 段（不使用 Repeat / PopNextSegment / SwitchSegmentType）====== -->
  <BehaviorTree ID="FinalArea">
    <Sequence>

      <Sequence name="FINAL_01_MOVE2">
        <RetrySegment num_attempts="3">
          <MoveToPose target_x="{final_move2_target_x}"
                      target_y="{final_move2_target_y}"
                      target_yaw="{final_move2_target_yaw}"
                      max_speed="{final_move2_max_speed}"
                      pid_profile="{final_move2_pid_profile}"
                      timeout_sec="{final_move2_timeout_sec}"
                      error_msg="{last_error}"/>
        </RetrySegment>
      </Sequence>

      <Sequence name="FINAL_02_FINAL_MOVE2">
        <RetrySegment num_attempts="3">
          <MoveToPose target_x="{final_final_move2_target_x}"
                      target_y="{final_final_move2_target_y}"
                      target_yaw="{final_final_move2_target_yaw}"
                      max_speed="{final_final_move2_max_speed}"
                      pid_profile="{final_final_move2_pid_profile}"
                      timeout_sec="{final_final_move2_timeout_sec}"
                      error_msg="{last_error}"/>
        </RetrySegment>
      </Sequence>

      <Sequence name="FINAL_03_PLACE_MID">
        <RetrySegment num_attempts="3">
          <Sequence>
            <WaitArmIdle timeout_sec="{final_place_mid_timeout_sec}"
                         message="{last_error}"/>
            <ArmAction command="{final_place_mid_arm_command}"
                       wait_result="true"
                       timeout_sec="{final_place_mid_timeout_sec}"
                       message="{last_error}"/>
          </Sequence>
        </RetrySegment>
      </Sequence>

      <Sequence name="FINAL_04_PLACE_HIGH">
        <RetrySegment num_attempts="3">
          <Sequence>
            <WaitArmIdle timeout_sec="{final_place_high_timeout_sec}"
                         message="{last_error}"/>
            <ArmAction command="{final_place_high_arm_command}"
                       wait_result="true"
                       timeout_sec="{final_place_high_timeout_sec}"
                       message="{last_error}"/>
          </Sequence>
        </RetrySegment>
      </Sequence>

      <Sequence name="FINAL_05_FINISH">
        <RetrySegment num_attempts="3">
          <Sequence>
            <WaitArmIdle timeout_sec="{final_finish_timeout_sec}"
                         message="{last_error}"/>
            <ArmAction command="{final_finish_arm_command}"
                       wait_result="true"
                       timeout_sec="{final_finish_timeout_sec}"
                       message="{last_error}"/>
            <SuspensionControl mode="{final_finish_suspension_mode}"
                               direction="{final_finish_suspension_direction}"
                               height="{final_finish_suspension_height}"
                               timeout_sec="{final_finish_suspension_timeout_sec}"
                               message="{last_error}"/>
          </Sequence>
        </RetrySegment>
      </Sequence>

    </Sequence>
  </BehaviorTree>

</root>
