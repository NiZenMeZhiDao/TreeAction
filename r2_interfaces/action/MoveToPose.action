# MoveToPose.action — 底盘精调 / 短距离位姿控制
#
# 对应 Motion PID server 的 /move_to_pose action。

uint8 PID_PROFILE_SLOW=0
uint8 PID_PROFILE_FAST=1

float64 x
float64 y
float64 yaw_deg
uint8 pid_profile
---
bool success
string message
---
string phase
float64 current_x
float64 current_y
float64 current_yaw_deg
float64 target_x
float64 target_y
float64 target_yaw_deg
float64 yaw_error_deg
float64 distance_error
float64 cmd_vx
float64 cmd_vy
float64 cmd_wz
