# Align.action — 底盘精调（区域内短距离直线运动，低速高精度）
#
# 区别于 MoveToPose（区域间导航），Align 用于：
#   准备区：矛头对准、对接位精调
#   梅林区：格间移动
#   竞技区：槽位精调
#
# 对应 Motion_control_accurate 的精调 action server

# Goal
float64 x          # 目标 X (map 坐标系, m)
float64 y          # 目标 Y (map 坐标系, m)
float64 yaw_deg    # 目标 yaw 角度 (度)
---
# Result
bool success
string message
---
# Feedback
string phase
float64 current_x
float64 current_y
float64 current_yaw_deg
float64 target_x
float64 target_y
float64 target_yaw_deg
float64 yaw_error_deg
float64 distance_error
float64 cmd_vx
float64 cmd_vy
float64 cmd_wz
