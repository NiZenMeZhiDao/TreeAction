<?xml version="1.0"?>
<!--
  meilin_stage.xml - 梅林赛段行为树

  树只分派 move/fetch；具体底盘、悬挂、机械臂编排封装在节点内部。
  Move/Fetch 内部自行完成 grid→world、爬台计算、抓取位姿计算。
  超时等配置从 blackboard 的 meilin_config 读取。
-->
<root BTCPP_format="4" main_tree_to_execute="MeilinStage">
  <BehaviorTree ID="MeilinStage">
    <ForEachSegment stop_type="PLAN_DONE">
      <Sequence>
        <PopNextMeilinSegment queue="{segment_queue}"
                              segment_type="{segment_type}"
                              move_row="{move_row}"
                              move_col="{move_col}"
                              target_height_mm="{target_height_mm}"
                              kfs_row="{kfs_row}"
                              kfs_col="{kfs_col}"
                              height_diff="{height_diff}"
                              target_yaw="{target_yaw}"/>

        <SwitchSegmentType segment_type="{segment_type}">
          <Move name="move"
                move_row="{move_row}"
                move_col="{move_col}"
                target_height_mm="{target_height_mm}"
                target_yaw="{target_yaw}"
                message="{last_error}"/>

          <Fetch name="fetch"
                 kfs_row="{kfs_row}"
                 kfs_col="{kfs_col}"
                 height_diff="{height_diff}"
                 target_yaw="{target_yaw}"
                 message="{last_error}"/>

          <Sequence name="PLAN_DONE">
            <SetDebugStatus execution_state="MISSION_SUCCESS" active_action="" last_error=""/>
          </Sequence>

          <Sequence name="default">
            <SetDebugStatus execution_state="ACTION_FAILED" active_action="MeilinDispatch"
                            last_error="Unsupported segment_type in MeilinStage"/>
          </Sequence>
        </SwitchSegmentType>
      </Sequence>
    </ForEachSegment>
  </BehaviorTree>
</root>
